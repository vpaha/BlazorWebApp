@page "/vendorprofile"
@attribute [Authorize(Policy = "Vendor")]
@inject IVendorRepo vendorRepo

<PageTitle>Vendor Profile | Property Claims</PageTitle>

<section>
    <VendorDetails Vendor="model"></VendorDetails>
</section>
@code {
    private VendorModel? model { get; set; }

    protected override async Task OnInitializedAsync()
    {
        model = await vendorRepo.GetVendorAsync();
    }
}