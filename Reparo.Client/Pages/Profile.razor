@page "/profile"
@rendermode InteractiveAuto
@attribute [Authorize]

@inject IAuthorizationService authz
@inject IVendorRepo vendorRepo
@inject ToastService toastService
@inject IUserService userService

<PageTitle>Profile | Property Claims</PageTitle>

<section class="zoom-in">
    <SfSpinner @bind-Visible="@isLoading"></SfSpinner>
    <AuthorizeView Policy="Vendor">
        <Authorized>
            <VendorDetails Vendor="model"></VendorDetails>
        </Authorized>
        <NotAuthorized>
            <UserContextInfo RefreshVersion="refreshVersion"></UserContextInfo>
        </NotAuthorized>
    </AuthorizeView>
    <AuthorizeView Policy="Admin">
        <Authorized>
            <UserList RefreshRequested="RefreshPageAsync"></UserList>
        </Authorized>
    </AuthorizeView>
</section>
@code {
    [CascadingParameter] private Task<AuthenticationState> authStateTask { get; set; } = default!;

    private VendorModel model { get; set; } = default!;
    private bool isLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var authState = await authStateTask;
            var result = await authz.AuthorizeAsync(authState.User, "Vendor");
            if (result.Succeeded)
            {
                model = await vendorRepo.GetVendorAsync();
            }
        } catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        } finally
        {
            isLoading = false;
        }
    }
    
    private int refreshVersion;

    private async Task RefreshPageAsync(AppUser user)
    {
        await userService.UpdateUserAsync(user);

        var authState = await authStateTask;
        await userService.ProvisionAsync(authState.User);

        refreshVersion++;
        StateHasChanged();

        toastService.ShowSuccess($"{authState.User.Identity?.Name}'s user updated successfully.");
    }

}