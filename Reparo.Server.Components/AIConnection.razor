@rendermode InteractiveServer

@inject IDamageAiService damageAiService
@inject ToastService toastService

<SfCard CssClass="@(IsDesktopView ? "max-width-400" : "max-width")">
    <CardContent>
        <div class="wdr-container">
            <SfSmartTextArea UserRole="property owner" Placeholder="Your name and how we can contact you (phone or email)" @bind-Value="DamageContext.ContactEntry"
                             ShowClearButton="true" FloatLabelType="FloatLabelType.Auto" Width="100%" Enabled="@(!isDisabled)"
                             RowCount="4" ShowSuggestionOnPopup="false">
            </SfSmartTextArea>
            <div class="wdr-icon">
                <SfButton type="button" CssClass="e-round e-outline" IsPrimary="true" OnClick="AiProcessAsync1">
                    <SfIcon Size="IconSize.Medium" Name="IconName.AIChat" Title="AI Process"></SfIcon>
                </SfButton>
                <div @onclick:preventDefault>
                    <SfSpeechToText @bind-Transcript="DamageContext.ContactEntry" SpeechRecognitionStopped="OnContactTranscriptChanged" />
                </div>
            </div>
        </div>
        <div class="validation-message">
            <ValidationMessage For="@(() => DamageContext.ContactEntry)" />
        </div>
    </CardContent>
</SfCard>
<SfCard CssClass="@(IsDesktopView ? "max-width-400" : "max-width")">
    <CardContent>
        <div class="wdr-container">
            <SfSmartTextArea UserRole="property owner" Placeholder="Your insurance carrier, policy number, and claim number" @bind-Value="DamageContext.InsuranceEntry"
                             ShowClearButton="true" FloatLabelType="FloatLabelType.Auto" Width="100%" Enabled="@(!isDisabled)"
                             RowCount="4" ShowSuggestionOnPopup="false">
            </SfSmartTextArea>
            <div class="wdr-icon">
                <SfButton type="button" CssClass="e-round e-outline" IsPrimary="true" OnClick="AiProcessAsync2">
                    <SfIcon Size="IconSize.Medium" Name="IconName.AIChat" Title="AI Process"></SfIcon>
                </SfButton>
                <div @onclick:preventDefault>
                    <SfSpeechToText @bind-Transcript="DamageContext.InsuranceEntry" SpeechRecognitionStopped="OnInsuranceTranscriptChanged" />
                </div>
            </div>
        </div>
        <div class="validation-message">
            <ValidationMessage For="@(() => DamageContext.InsuranceEntry)" />
        </div>
    </CardContent>
</SfCard>
<AddressEntry DamageContext="DamageContext" AddressChanged="AddressChanged"></AddressEntry>
@code {
    [CascadingParameter(Name = CascadingParams.MediaQuery)] private bool IsDesktopView { get; set; }
    [CascadingParameter] private EditContext EditContext { get; set; } = default!;
    [Parameter] public DamageEntry DamageContext { get; set; } = default!;

    private bool isDisabled { get; set; }

    private void OnContactTranscriptChanged(SpeechRecognitionStoppedEventArgs args)
    {
        DamageContext.ContactEntry = args.Transcript;
        EditContext.NotifyFieldChanged(new FieldIdentifier(DamageContext, nameof(DamageContext.ContactEntry)));
    }

    private void OnInsuranceTranscriptChanged(SpeechRecognitionStoppedEventArgs args)
    {
        DamageContext.InsuranceEntry = args.Transcript;
        EditContext.NotifyFieldChanged(new FieldIdentifier(DamageContext, nameof(DamageContext.InsuranceEntry)));
    }

    private void AddressChanged(bool isValid)
    {
        EditContext.NotifyFieldChanged(new FieldIdentifier(DamageContext, nameof(DamageContext.AddressEntry)));
    }

    private async Task AiProcessAsync1()
    {
        if (!string.IsNullOrWhiteSpace(DamageContext.ContactEntry))
        {
            try
            {
                isDisabled = true;
                DamageContext.ContactEntry = await damageAiService.ProcessTextAsync(DamageContext.ContactEntry, CancellationToken.None);
            } catch (Exception ex)
            {
                toastService.ShowError(ex.Message);
            } finally
            {
                isDisabled = false;
            }
        }
    }

    private async Task AiProcessAsync2()
    {
        if (!string.IsNullOrWhiteSpace(DamageContext.InsuranceEntry))
        {
            try
            {
                isDisabled = true;
                DamageContext.InsuranceEntry = await damageAiService.ProcessTextAsync(DamageContext.InsuranceEntry, CancellationToken.None);
            } catch (Exception ex)
            {
                toastService.ShowError(ex.Message);
            } finally
            {
                isDisabled = false;
            }
        }
    }
}
