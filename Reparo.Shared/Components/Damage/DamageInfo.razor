@inject IDamageRepo damageRepo

<SfCard role="link">
    <CardContent>
        <div class="spread-across">
            <Description DamageContext="DamageContext"></Description>
            <div>
                <SfButton type="button" IsPrimary="true" CssClass="e-outline" OnClick="ToggleBlade" Content="@(IsBladeOpen ? "Hide" : "Review damage report")" IconCss="@(IsBladeOpen ? "e-icons e-eye-slash" : "e-icons e-eye")" IconPosition="IconPosition.Right" title="Review damage report">
                </SfButton>
            </div>
        </div>
    </CardContent>
    <CardContent EnableSeparator="true">
        <div class="spread-across">
            <SfMessage Severity="@GetSeverity(DamageContext.StatusId)">@((DamageStatus)DamageContext.StatusId)</SfMessage>
            <SfButton type="button" CssClass="e-success e-outline" OnClick="OnReview"
                      Content="Review by AI" IconCss="e-icons e-resizer-1"
                      IconPosition="IconPosition.Right" title="Review by AI"></SfButton>
            <SfButton type="button"
                      OnClick="OnSubmit"
                      IconCss="e-icons e-check" IconPosition="IconPosition.Right" IsPrimary="true"
                      CssClass="@(DamageContext.StatusId==(int)DamageStatus.Reported?"":"e-outline")"
                      Content="@(DamageContext.StatusId==(int)DamageStatus.Reported?"Proceed with Service":"Scheduled")" title="Proceed with Service">
            </SfButton>
        </div>
    </CardContent>
</SfCard>
@code {
    [Parameter] public DamageEntry DamageContext { get; set; } = default!;
    [Parameter] public bool IsBladeOpen { get; set; } = default!;
    [Parameter] public EventCallback<DamageEntry> OnToggleBladeEvent { get; set; }

    private async Task ToggleBlade()
    {
        await OnToggleBladeEvent.InvokeAsync(DamageContext);
    }

    private async Task OnSubmit()
    {
        DamageContext.StatusId = DamageContext.StatusId == (int)DamageStatus.ServiceScheduled ? (int)DamageStatus.Reported : (int)DamageStatus.ServiceScheduled;
        await damageRepo.UpdateEntryAsync(DamageContext, CancellationToken.None);
    }

    private async Task OnReview()
    {
        var result = await damageRepo.ReviewEntryAsync(DamageContext, CancellationToken.None);
        if (result)
        {
            DamageContext.StatusId = (int)DamageStatus.InspectionCompleted;
            await damageRepo.UpdateEntryAsync(DamageContext, CancellationToken.None);
        }
    }
    
    private MessageSeverity GetSeverity(int statusId)
    {
        return (DamageStatus)statusId switch
        {
            DamageStatus.Reported or DamageStatus.WaitingForVendorAssignment or DamageStatus.EstimatePending
                => MessageSeverity.Normal,
            DamageStatus.VendorAssigned or DamageStatus.ServiceScheduled or DamageStatus.InspectionScheduled
                => MessageSeverity.Success,

            DamageStatus.WorkInProgress
                => MessageSeverity.Warning,

            DamageStatus.WorkCompleted or DamageStatus.Closed
                => MessageSeverity.Success,

            DamageStatus.Cancelled
                => MessageSeverity.Error,

            DamageStatus.OnHold
                => MessageSeverity.Warning,

            _ => MessageSeverity.Normal
        };
    }
}