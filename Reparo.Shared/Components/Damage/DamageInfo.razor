@inject IDamageRepo damageRepo
@inject IDamageAiService damageAiService
@inject ToastService toastService

<SfSpinner Size="48" Type="SpinnerType.Material" @bind-Visible="@isLoading"></SfSpinner>
<SfCard role="link">
    <CardContent>
        <div class="spread-across">
            <Description DamageContext="DamageContext"></Description>
            <SfMessage Severity="@DamageContext.GetSeverity()" Variant="MessageVariant.Filled">@((DamageStatus)DamageContext.StatusId)</SfMessage>
            <SfButton type="button" IsPrimary="true" CssClass="e-outline" OnClick="ToggleBlade"
                      Content="@(IsBladeOpen ? "Hide" : "Review damage report")" IconCss="@(IsBladeOpen ? "e-icons e-eye-slash" : "e-icons e-eye")"
                      IconPosition="IconPosition.Right" title="Review damage report">
            </SfButton>
        </div>
    </CardContent>
    <CardContent EnableSeparator="true">
        <div class="spread-across">
            <SfButton type="button" CssClass="e-success e-outline" OnClick="OnReview"
                      Content="Review by AI" IconCss="e-icons e-resizer-1"
                      IconPosition="IconPosition.Right" title="Review by AI"></SfButton>
            <SfButton type="button"
                      OnClick="OnSubmit"
                      IconCss="e-icons e-check" IconPosition="IconPosition.Right" IsPrimary="true"
                      CssClass="@(DamageContext.StatusId==(int)DamageStatus.Reported?"":"e-outline")"
                      Content="@(DamageContext.StatusId==(int)DamageStatus.Reported?"Proceed with Service":"Scheduled")" title="Proceed with Service">
            </SfButton>
        </div>
    </CardContent>
</SfCard>
@code {
    [Parameter] public DamageEntry DamageContext { get; set; } = default!;
    [Parameter] public bool IsBladeOpen { get; set; } = default!;
    [Parameter] public EventCallback<DamageEntry> OnToggleBladeEvent { get; set; }

    private bool isLoading { get; set; }

    private async Task ToggleBlade()
    {
        await OnToggleBladeEvent.InvokeAsync(DamageContext);
    }

    private async Task OnSubmit()
    {
        DamageContext.StatusId = DamageContext.StatusId == (int)DamageStatus.ServiceScheduled ? (int)DamageStatus.Reported : (int)DamageStatus.ServiceScheduled;
        await damageRepo.UpdateEntryAsync(DamageContext, CancellationToken.None);
    }

    private async Task OnReview()
    {
        try
        {
            isLoading = true;

            await damageAiService.ProcessEntryAsync(DamageContext, CancellationToken.None);
            toastService.ShowSuccess("Damage report reviewed by AI");
        } catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        } finally
        {
            isLoading = false;
        }
    }
}