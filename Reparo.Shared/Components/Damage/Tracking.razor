@inject SfDialogService dialogService
@inject IVendorRepo vendorRepo

<SfDialog Width="90vw" ShowCloseIcon="true" @bind-Visible="IsSearchDialogOpen">
    <DialogTemplates>
        <Header>Local contractors near the property</Header>
        <Content>
            <GoogleMap Latitude="DamageContext.Latitude" Longitude="DamageContext.Longitude" OnSelectionEvent="SelectedVendor" />
        </Content>
    </DialogTemplates>
</SfDialog>
<SfCard role="link">
    <CardContent EnableSeparator="true">
        <div class="spread-across">
            <div id="damage-summary">
                <div>
                    Damage reported on @($"{DamageContext.DateOfLoss:g}")
                </div>
                @{
                    foreach (var item in DamageContext.Sections)
                        if (!string.IsNullOrWhiteSpace(item.Entry))
                        {
                            <div>
                                Requested <strong>@item.DamageSectionType?.Name</strong>
                                <div>@item.Entry</div>
                            </div>
                        }
                }
            </div>
            <div>
                <SfButton type="button" CssClass="e-outline e-primary" OnClick="ToggleBlade" Content="@(IsBladeOpen ? "Hide" : "Review damage")"
                          IconCss="@(IsBladeOpen ? "e-icons e-eye-slash" : "e-icons e-eye")" IconPosition="IconPosition.Right" title="Review damage">
                </SfButton>
            </div>
        </div>
    </CardContent>
    <CardContent EnableSeparator="true">
        @if (DamageContext.Vendor is not null)
        {
            <div class="spread-across">
                <SfButton CssClass="e-success e-outline" OnClick="ShowVendor" title="View Vendor Details">@DamageContext.Vendor.Name</SfButton>
                <SfMessage Severity="@GetSeverity(DamageContext.StatusId)">@((DamageStatus)DamageContext.StatusId)</SfMessage>
                <SfButton type="button" OnClick="OnChat" IconCss="e-icons e-comment-show" IconPosition="IconPosition.Right" IsPrimary="true"
                          CssClass="e-outline"
                          Content="Chat" title="Chat with Vendor">
                </SfButton>
            </div>
        }
        else
        {
            <SfButton type="button" CssClass="e-info e-outline" OnClick="toggleSearch"
                      Content="Find a local contractor" IconCss="e-icons e-search"
                      IconPosition="IconPosition.Right" title="Find a local contractor"></SfButton>
            <h3>No Contractor is selected</h3>
        }
    </CardContent>
    <CardContent EnableSeparator="true">
        <SfButton type="button" CssClass="e-outline" IsPrimary="true"
                  Content="Request insurance coverage" IconCss="e-icons e-resizer-1"
                  IconPosition="IconPosition.Right" title="Request insurance coverage"></SfButton>
    </CardContent>
</SfCard>
<style>
    #damage-summary {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
</style>
@code {
    [Parameter] public DamageEntry DamageContext { get; set; } = default!;
    [Parameter] public bool IsBladeOpen { get; set; } = default!;
    [Parameter] public EventCallback<DamageEntry> OnToggleBladeEvent { get; set; }

    private bool IsSearchDialogOpen;

    private async Task ToggleBlade()
    {
        await OnToggleBladeEvent.InvokeAsync(DamageContext);
    }

    private async Task ShowVendor()
    {
        await dialogService.AlertAsync(null, DamageContext.Vendor?.Name, new DialogOptions
        {
            ShowCloseIcon = true,
            PrimaryButtonOptions = new DialogButtonOptions
            {
                Content = "Close", IconCss = "e-icons e-close"
            },
            AnimationSettings = new DialogAnimationOptions
            {
                Effect = DialogEffect.FlipXUp
            },
            ChildContent = builder =>
            {
                builder.OpenComponent<VendorDetails>(0);
                builder.AddAttribute(1, "Vendor", DamageContext.Vendor);
                builder.CloseComponent();
            }
        });
    }

    private async Task RemoveVendor()
    {
        DamageContext.Vendor = null;
        DamageContext.VendorId = null;
        StateHasChanged();
    }

    private async Task toggleSearch()
    {
        IsSearchDialogOpen = true;
    }

    private async Task SelectedVendor(string placeId)
    {
        try
        {
            DamageContext.Vendor = await vendorRepo.GetVendorByPlaceAsync(placeId);
            DamageContext.VendorId = DamageContext.Vendor?.Id;
        } catch (Exception)
        {
        } finally
        {
            IsSearchDialogOpen = false;
        }
    }

    private MessageSeverity GetSeverity(int statusId)
    {
        return (DamageStatus)statusId switch
        {
            DamageStatus.Reported or DamageStatus.WaitingForVendorAssignment or DamageStatus.EstimatePending
                => MessageSeverity.Normal,
            DamageStatus.VendorAssigned or DamageStatus.ServiceScheduled or DamageStatus.InspectionScheduled
                => MessageSeverity.Success,

            DamageStatus.WorkInProgress
                => MessageSeverity.Warning,

            DamageStatus.WorkCompleted or DamageStatus.Closed
                => MessageSeverity.Success,

            DamageStatus.Cancelled
                => MessageSeverity.Error,

            DamageStatus.OnHold
                => MessageSeverity.Warning,

            _ => MessageSeverity.Normal
        };
    }

    private async Task OnChat()
    {
    }
}