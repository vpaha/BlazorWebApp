@if (claim is not null)
{
    <SfCard ID="claim-container" role="region">
        <CardContent>
            <h3>Claim Details:</h3>
            @foreach (var prop in claim.GetType().GetProperties())
            {
                <div>@prop.Name: @prop.GetValue(claim)</div>
            }
        </CardContent>
        <CardContent EnableSeparator="true">
            <input type="button" class="e-success e-outline" value="Attachments" onclick="Attachment('@claim.ClaimId')" />
        </CardContent>
    </SfCard>
}
<style>
    #claim-container .e-card-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        padding: 5px;
    }
</style>
<script>
    async function Attachment(claimId)
    {
        await renderAttachment('Claim', claimId);
    }
</script>
@code {
    [Parameter] public ClaimSearchResponse claim { set; get; } = default!;
}