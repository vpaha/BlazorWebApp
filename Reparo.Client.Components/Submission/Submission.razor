@rendermode InteractiveAuto

@inject IJSRuntime jSRuntime
@inject NavigationManager nav
@inject ToastService toastService
@inject IDamageRepo damageRepo

@if (EditContext is not null)
{
    <CascadingValue Value="EditContext" IsFixed="false">
        <SfDataForm EditContext="@EditContext" LabelPosition="FormLabelPosition.Top"
                    ButtonsAlignment="FormButtonsAlignment.Center" EnableFloatingLabel="true">
            <FormValidator>
                <DataAnnotationsValidator></DataAnnotationsValidator>
            </FormValidator>
            <FormTemplate>
                <SfStepper ID="stepper-container" ActiveStep="currentStep" Orientation="StepperOrientation.Horizontal"
                           LabelPosition="StepperLabelPosition.Bottom" StepClicked="@StepClicked">
                    <ChildContent>
                        <StepperSteps>
                            <StepperStep @ref="stepperStep1" Label="Damage" IconCss="sf-icon-transport"></StepperStep>
                            <StepperStep @ref="stepperStep3" Label="Connect" IconCss="sf-icon-success"></StepperStep>
                        </StepperSteps>
                    </ChildContent>
                </SfStepper>
                <div id="subm-container">
                    @if (currentStep == 0)
                    {
                        foreach (var item in DamageContext.Sections)
                        {
                            <Trade DamageSection="item"></Trade>
                        }
                    }
                    else if (currentStep == 1)
                    {
                        <Connection DamageContext="DamageContext"></Connection>
                    }
                    <SfCard role="article" CssClass="zoom-in">
                        <CardContent>
                            <VendorSearch DamageContext="DamageContext"></VendorSearch>
                        </CardContent>
                        <CardContent EnableSeparator="true">
                            <ValidationSummary></ValidationSummary>
                        </CardContent>
                    </SfCard>
                </div>
            </FormTemplate>
            <FormButtons>
                <SfButton type="submit" CssClass="e-primary" OnClick="TriggerSubmit" Content="Submit the Report" IconCss="e-icons e-circle-check" IconPosition="IconPosition.Left" title="Submit the Report">
                </SfButton>
                <SfButton type="reset" title="Clear Fields" CssClass="e-outline">Clear</SfButton>
            </FormButtons>
        </SfDataForm>
    </CascadingValue>
}
<style>
    #subm-container {
        padding-left: 2px;
        padding-right: 2px;
        padding-bottom: 10px;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        column-gap: 10px;
        row-gap: 6px;
    }

    #sideBar-container {
        border-radius: 8px;
        padding: 10px 15px 10px 15px;
        overflow: hidden;
    }

    #stepper-container {
        margin-top: 10px;
        margin-bottom: 6px;
    }

    .sf-icon-transport:before {
        content: "\e702";
    }

    .sf-icon-user:before {
        content: "\e708";
    }

    .sf-icon-success:before {
        content: "\e715";
    }
</style>
@code {
    [Inject]
    private DamageState DamageState { get; set; } = default!;
    public DamageEntry DamageContext => DamageState.Context;

    public EditContext EditContext { get; set; } = default!;

    private StepperStep? stepperStep1;
    private StepperStep? stepperStep3;

    private int currentStep { get; set; } = 0;

    public void StepClicked(StepperClickedEventArgs args)
    {
        currentStep = args.ActiveStep;

        if (currentStep == 1)
        {
            var isStepValid = EditContext.Validate();

            stepperStep1?.IsValid = isStepValid;
            stepperStep3?.IsValid = isStepValid;
        }
        else
        {
            stepperStep1?.IsValid = null;
            stepperStep3?.IsValid = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            IReadOnlyList<DamageSectionType> types = await damageRepo.ListSectionTypesAsync(CancellationToken.None);

            DamageContext.Sections = types.Select(t => new DamageEntrySection
            {
                DamageSectionId = t.Id,
                DamageSectionType = new DamageSectionType
                {
                    Id = t.Id,
                    Name = t.Name,
                    Description = t.Description,
                    IsEmergency = t.IsEmergency
                },
                CreatedAt = DateTimeOffset.UtcNow,
                Entry = null
            })
            .ToList();

            EditContext = new EditContext(DamageContext);
        } catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        }
    }

    private async Task TriggerSubmit()
    {
        if (EditContext is null) return;
        var isValid = EditContext.Validate();

        var sectionsField = new FieldIdentifier(DamageContext, nameof(DamageEntry.Sections));
        if (EditContext.GetValidationMessages(sectionsField).Any())
        {
            currentStep = 0;
            return;
        }
        else if (!isValid)
        {
            currentStep = 1;
            return;
        }

        try
        {
            DamageContext.DateOfLoss = DateTime.UtcNow;
            DamageContext.StatusId = DamageStatus.Reported;

            DamageContext.Sections.RemoveAll(s => string.IsNullOrWhiteSpace(s.Entry));
            DamageContext.Vendor = null;

            var claimId = await damageRepo.AddEntryAsync(DamageContext, CancellationToken.None);

            toastService.ShowSuccess($"Claim #{claimId} has been saved.", "System");
            nav.NavigateTo("requests");
        } catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        }
    }
}