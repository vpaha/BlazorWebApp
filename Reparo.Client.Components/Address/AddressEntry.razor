@inject NavigationManager nav
@inject HttpClient httpClient
@inject ToastService toastService

<SfCard CssClass="@(IsDesktopView ? "max-width-400" : "max-width")">
    <CardContent>
        <div class="wdr-container">
            <SfTextBox @bind-Value="DamageContext.AddressEntry" Placeholder="Property Address" ShowClearButton="true"
                       FloatLabelType="FloatLabelType.Auto" OnChange="onChanged" Width="100%" />
            <div @onclick:preventDefault style="align-self:end">
                <SfSpeechToText @bind-Transcript="DamageContext.AddressEntry" CssClass="e-info e-outline e-primary" SpeechRecognitionStopped="OnTranscriptChanged" />
            </div>
        </div>
        <div class="validation-message">
            <ValidationMessage For="@(() => DamageContext.AddressEntry)" />
        </div>
        <div style="margin-top:5px;">
            Explore repair services for this address
            <SfButton type="button" title="Verify Address" CssClass="e-round e-outline e-primary" OnClick="VerifyLocation">
                <SfIcon Size="IconSize.Medium" Name="IconName.Reset" Title="Verify Address"></SfIcon>
            </SfButton>
        </div>
    </CardContent>
</SfCard>
@if (_isMapEnabled)
{
    @if (ShowMap)
    {
        <SfCard CssClass="@(IsDesktopView ? "max-width-400" : "max-width")">
            <CardContent>
                <label id="map-label">
                    @DamageContext.Placename
                </label>
                @if (IsDesktopView)
                {
                    <LocalMap Latitude="@DamageContext.Latitude" Longitude="@DamageContext.Longitude"></LocalMap>
                }
            </CardContent>
        </SfCard>
    }
}
else
{
    <AddressLookup AddressResolved="OnAddressResolved"></AddressLookup>
}
@code {
    [CascadingParameter(Name = CascadingParams.MediaQuery)] private bool IsDesktopView { get; set; }

    [Parameter] public DamageEntry DamageContext { get; set; } = default!;
    [Parameter] public EventCallback<bool> AddressChanged { get; set; }
    [Parameter] public bool ShowMap { get; set; } = default!;

    private bool _isMapEnabled = false;

    protected override void OnInitialized()
    {
        if (DamageContext.AddressEntry != null) _isMapEnabled = true;
    }

    private async Task OnTranscriptChanged(SpeechRecognitionStoppedEventArgs args)
    {
        DamageContext.AddressEntry = args.Transcript;

        await AddressChanged.InvokeAsync(false);
    }

    private async Task OnAddressResolved(LocationDto location)
    {
        DamageContext.GoogleId = location.PlaceId;
        DamageContext.Latitude = location.Latitude;
        DamageContext.Longitude = location.Longitude;
        DamageContext.AddressEntry = location.Address;

        DamageContext.Region = location.Region;
        DamageContext.Placename = location.Placename;

        _isMapEnabled = true;

        await AddressChanged.InvokeAsync(false);
    }

    private async Task onChanged()
    {
        await AddressChanged.InvokeAsync(true);
    }

    private async Task VerifyLocation()
    {
        var absoluteUrl = nav.ToAbsoluteUri($"googlemap/geocode/lookup?address={DamageContext.AddressEntry}");

        using var response = await httpClient.GetAsync(absoluteUrl);
        if (response.IsSuccessStatusCode)
        {
            var place = await response.Content.ReadFromJsonAsync<LocationDto>();
            if (place != null) await OnAddressResolved(place);
        }
        else
        {
            _isMapEnabled = false;
            toastService.ShowWarning("Address not found", "Location");
        }
    }
}