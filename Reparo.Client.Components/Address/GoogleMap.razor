@using Microsoft.Extensions.Hosting;

@inject IJSRuntime jSRuntime
@inject SfDialogService dialogService
@inject IHostEnvironment env

@implements IAsyncDisposable

<div class="fade-in">
    <gmp-map id="nearbymap" role="region"></gmp-map>
</div>
<style>
    #nearbymap {
        height: 400px;
    }
</style>

@code {
    [Parameter] public double? Latitude { get; set; }
    [Parameter] public double? Longitude { get; set; }
    [Parameter] public EventCallback<string> OnSelectionEvent { get; set; }
    [Parameter] public EventCallback<bool> OnConfirmEvent { get; set; }

    private DotNetObjectReference<GoogleMap>? _objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (Latitude != null && Longitude != null)
        {
            _objRef = DotNetObjectReference.Create(this);
            await jSRuntime.InvokeVoidAsync("googleMap.initMap", "nearbymap", Latitude, Longitude, 16, _objRef);
            if (!env.IsDevelopment())
            {
                await jSRuntime.InvokeVoidAsync("googleMap.fetchPlaces", "general contractor");
            }
        }
    }

    [JSInvokable]
    public async Task OpenVendor(PlaceDto? place)
    {
        if (!OnSelectionEvent.HasDelegate)
        {
            bool isConfirm = await dialogService.ConfirmAsync(null, place?.Name,
                new DialogOptions
                {
                    CssClass = "popup-dialog",
                    PrimaryButtonOptions = new DialogButtonOptions
                    {
                        Content = "Continue", IconCss = "e-icons e-check-large"
                    },
                    CancelButtonOptions = new DialogButtonOptions
                    {
                        Content = "Close", IconCss = "e-icons e-close"
                    },
                    AnimationSettings = new DialogAnimationOptions
                    {
                        Effect = DialogEffect.FlipXUp
                    },
                    ChildContent = builder =>
                    {
                        builder.OpenComponent<Vendor>(0);
                        builder.AddAttribute(1, "PlaceId", place?.Id);
                        builder.CloseComponent();
                    }
                });
            await OnConfirmEvent.InvokeAsync(isConfirm);
        }
        else
        {
            await OnSelectionEvent.InvokeAsync(place?.Id);
        }
    }

    public ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}