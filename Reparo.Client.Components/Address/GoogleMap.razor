@using Microsoft.Extensions.Hosting

@inject IJSRuntime jSRuntime
@inject SfDialogService DialogService
@inject IHostEnvironment env
@inject IVendorRepo vendorRepo

@implements IAsyncDisposable

<SfCard ID="map-container3" CssClass="map-container fade-in">
    <gmp-map role="region"></gmp-map>
</SfCard>

<style>
    #map-container3 {
        height: 400px;
    }
</style>

@code
{
    [Parameter] public DamageEntry DamageContext { get; set; } = default!;
    [Parameter] public EventCallback OnSelectionEvent { get; set; }

    private DotNetObjectReference<GoogleMap>? _objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (DamageContext is null) return;

        _objRef = DotNetObjectReference.Create(this);
        await jSRuntime.InvokeVoidAsync("googleMap.initMap", "#map-container3 > gmp-map", DamageContext.Latitude, DamageContext.Longitude, 16);
        int maxResults = env.IsDevelopment() ? 2 : 10;
        await jSRuntime.InvokeVoidAsync("googleMap.fetchPlaces", "general contractor", maxResults, _objRef);
    }

    [JSInvokable]
    public async Task OpenVendor(PlaceDto place)
    {
        bool confirmed = await DialogService.ConfirmAsync("Choose this vendor? (You can select a different one later)", place.Name,
            new DialogOptions
            {
                CssClass = "popup-dialog",
                PrimaryButtonOptions = new DialogButtonOptions
                {
                    Content = "Confirm",
                    IconCss = "e-icons e-check-large"
                },
                CancelButtonOptions = new DialogButtonOptions
                {
                    Content = "No",
                    IconCss = "e-icons e-close"
                },
                AnimationSettings = new DialogAnimationOptions
                {
                    Effect = DialogEffect.FlipXUp
                }
            });
        if (confirmed)
        {
            DamageContext.Vendor = await vendorRepo.GetVendorByPlaceAsync(place.PlaceId);
            DamageContext.VendorId = DamageContext.Vendor?.Id;
            DamageContext.StatusId = DamageStatus.VendorAssigned;

            await OnSelectionEvent.InvokeAsync();
        }
    }

    public ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}