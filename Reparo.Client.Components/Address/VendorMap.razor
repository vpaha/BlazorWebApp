@using Microsoft.Extensions.Hosting;

@inject IJSRuntime jSRuntime
@inject IHostEnvironment env

<SfCard ID="map-container1" CssClass="@(IsDesktopView ? "map-container max-width-400" : "map-container max-width")">
    <gmp-map role="region"></gmp-map>
</SfCard>

<style>
    #map-container1 {
        height: 400px;
    }
</style>

@code {
    [CascadingParameter(Name = CascadingParams.MediaQuery)] private bool IsDesktopView { get; set; }
    [Parameter] public double? Latitude { get; set; }
    [Parameter] public double? Longitude { get; set; }
    [Parameter] public string? PlaceId { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (PlaceId is not null)
        {
            await jSRuntime.InvokeVoidAsync("googleMap.initMap", "#map-container1 > gmp-map", Latitude, Longitude);
            if (!env.IsDevelopment())
            {
                await jSRuntime.InvokeVoidAsync("googleMap.searchPlaceById", PlaceId);
            }
        }
    }
}