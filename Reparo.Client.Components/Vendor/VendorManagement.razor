@using Microsoft.Extensions.Hosting;

@inject IJSRuntime jSRuntime
@inject IHostEnvironment environment
@inject IVendorRepo vendorRepo
@inject SfDialogService dialogService

@implements IAsyncDisposable

<section class="zoom-in">
    <SfSpinner @bind-Visible="@isLoading" Label=@($"Looking for {category}")>></SfSpinner>
    <SfDataForm EditContext="@EditContext" LabelPosition="FormLabelPosition.Top" ButtonsAlignment="FormButtonsAlignment.Center" EnableFloatingLabel="true">
        <FormValidator>
            <DataAnnotationsValidator></DataAnnotationsValidator>
        </FormValidator>
        <FormTemplate>
            <SfCard>
                <CardHeader>
                    <h2>Vendor management</h2>
                </CardHeader>
                <CardContent EnableSeparator="true">
                    <div class="spread-across">
                        <SfButton type="button" IsPrimary="true" OnClick="ShowPlaces" IconCss="e-icons e-kpi" IconPosition="IconPosition.Right">Vendor list</SfButton>
                        <SfDropDownList TItem="string" TValue="string" DataSource="@categories" @bind-Value="category" Width="300px" FloatLabelType="FloatLabelType.Never"
                                        Placeholder="groups" CssClass="e-primary">
                        </SfDropDownList>
                        <SfMessage CssClass="category-header" Variant="MessageVariant.Text" ShowIcon="false" Severity="MessageSeverity.Success">Selected category: @category</SfMessage>
                        <AddressEntry DamageContext="location" AddressChanged="AddressChanged" ShowMap="false"></AddressEntry>
                    </div>
                </CardContent>
            </SfCard>
        </FormTemplate>
        <FormButtons>
            <SfButton type="submit" Disabled="_isValid" IsPrimary="true" OnClick="UpdatePlaces">Explore vendors</SfButton>
        </FormButtons>
    </SfDataForm>
    <SfCard ID="map-container4" CssClass="map-container slide-in">
        <gmp-map role="region"></gmp-map>
    </SfCard>
    <SfCard>
        <CardContent EnableSeparator="true">
            <div class="places-container">
                @foreach (var item in places)
                {
                    <PlaceCard item="item"></PlaceCard>
                }
            </div>
        </CardContent>
    </SfCard>
</section>
<style>
    #map-container4 {
        height: 400px;
    }

    .category-header {
        align-self: normal;
    }

    .places-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vendor-card {
        padding: 10px 12px;
        border-bottom: 1px solid #e0e0e0;
        font-size: 0.9rem;
        line-height: 1.35;
    }

    .vendor-title {
        font-weight: 600;
        color: #202124;
        margin-bottom: 2px;
    }

    .vendor-line {
        color: #5f6368;
    }
</style>
@code {
    public EditContext EditContext { get; set; } = default!;

    DamageEntry location { get; set; } = new();

    string? category { get; set; }
    string[] categories = new[] { "general contractor", "plumber", "electrician", "roofer", "painter" };

    private bool isLoading { get; set; } = false;
    private bool _isValid;

    private PlaceDto[] places { get; set; } = [];
    private DotNetObjectReference<VendorManagement>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        EditContext = new EditContext(location);
        category = categories[0];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _objRef = DotNetObjectReference.Create(this);
    }

    public ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        return ValueTask.CompletedTask;
    }

    private void AddressChanged(bool isValid)
    {
        _isValid = isValid;
        if (!isValid) EditContext.Validate();
    }

    private async Task UpdatePlaces()
    {
        isLoading = true;
        await jSRuntime.InvokeVoidAsync("googleMap.initMap", "#map-container4 > gmp-map", location.Latitude, location.Longitude, 16, _objRef, "OnPlacesMapped");
        await jSRuntime.InvokeVoidAsync("googleMap.fetchPlaces", category, 60);
        isLoading = false;
    }

    [JSInvokable]
    public async Task OnPlacesMapped(PlaceDto[]? placesDto)
    {
        if (placesDto is not null)
        {
            places = placesDto;
            await vendorRepo.AddVendorsAsync(placesDto);
        }
        return;
    }

    private async Task ShowPlaces()
    {
        await dialogService.AlertAsync(null, "Vendor list", new DialogOptions
        {
            CssClass = "popup-dialog",
            ShowCloseIcon = true,
            Height = "90vh",

            PrimaryButtonOptions = new DialogButtonOptions
            {
                Content = "Close", IconCss = "e-icons e-close"
            },
            ChildContent = builder =>
            {
                builder.OpenComponent<VendorList>(0);
                builder.CloseComponent();
            }
        });
    }
}