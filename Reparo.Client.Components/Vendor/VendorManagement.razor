@using Microsoft.Extensions.Hosting;
@using System.ComponentModel.DataAnnotations
@inject IJSRuntime jSRuntime
@inject IHostEnvironment environment

@implements IAsyncDisposable

<SfDataForm EditContext="@EditContext" LabelPosition="FormLabelPosition.Top"
            ButtonsAlignment="FormButtonsAlignment.Center" EnableFloatingLabel="true">
    <FormValidator>
        <DataAnnotationsValidator></DataAnnotationsValidator>
    </FormValidator>
    <FormTemplate>
        <SfCard>
            <CardHeader>
                <h2>Vendor management</h2>
                @if (isRunning)
                {
                    <progress></progress>
                    <div>Looking for general contractors</div>
                }
            </CardHeader>
            <CardContent EnableSeparator="true">
                <SfDropDownList TItem="string" TValue="string" DataSource="@categories" @bind-Value="category" Width="300px"
                                Placeholder="Select a category">
                </SfDropDownList>
            </CardContent>
            <CardContent>
                <AddressEntry DamageContext="location" AddressChanged="AddressChanged" ShowMap="false"></AddressEntry>
            </CardContent>
        </SfCard>
    </FormTemplate>
    <FormButtons>
        <SfButton type="submit" Disabled="_isValid" IsPrimary="true" OnClick="UpdateVendors">Fetch vendors</SfButton>
    </FormButtons>
</SfDataForm>
<SfCard>
    <CardContent EnableSeparator="true">
        <gmp-map id="localmap" role="region"></gmp-map>
    </CardContent>
</SfCard>
<style>
    #localmap {
        height: 400px;
    }
</style>

@code {
    public EditContext EditContext { get; set; } = default!;

    DamageEntry location { get; set; } = new();

    string? category { get; set; }
    string[] categories = new[] { "general contractor", "plumber", "electrician", "roofer", "painter" };

    private bool isRunning { get; set; } = false;
    private bool _isValid;

    private DotNetObjectReference<VendorManagement>? _objRef;

    protected override void OnInitialized()
    {
        EditContext = new EditContext(location);
        category = categories[0];
    }

    private void AddressChanged(bool isValid)
    {
        _isValid = isValid;
        if (!isValid) EditContext.Validate();
    }

    private async Task UpdateVendors()
    {
        isRunning = true;

        //   if (!environment.IsDevelopment())
        // {
        await jSRuntime.InvokeVoidAsync("googleMap.searchPlaces", location.Latitude, location.Longitude, category);
        isRunning = false;
        //}
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _objRef = DotNetObjectReference.Create(this);
        await jSRuntime.InvokeVoidAsync("googleMap.initMap", "localmap", location.Latitude, location.Longitude, 13, _objRef);
    }

    public ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        return ValueTask.CompletedTask;
    }

    [JSInvokable]
    public async Task OpenMapDialogAsync(string placeId, string vendorName)
    {
    }    
}