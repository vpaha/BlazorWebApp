@using Microsoft.Extensions.Hosting;
@inject IJSRuntime jSRuntime
@inject IHostEnvironment environment
@inject IVendorRepo vendorRepo
@implements IAsyncDisposable

<section class="zoom-in">
    <SfSpinner @bind-Visible="@isLoading" Label=@($"Looking for {category}")>></SfSpinner>
    <SfDataForm EditContext="@EditContext" LabelPosition="FormLabelPosition.Top" ButtonsAlignment="FormButtonsAlignment.Center" EnableFloatingLabel="true">
        <FormValidator>
            <DataAnnotationsValidator></DataAnnotationsValidator>
        </FormValidator>
        <FormTemplate>
            <SfCard>
                <CardHeader>
                    <h2>Vendor management</h2>
                </CardHeader>
                <CardContent EnableSeparator="true">
                    <div class="spread-across">
                        <SfMessage CssClass="category-header" Variant="MessageVariant.Outlined" ShowIcon="false" Severity="MessageSeverity.Success">Categories</SfMessage>
                        <SfDropDownList TItem="string" TValue="string" DataSource="@categories" @bind-Value="category" Width="300px" FloatLabelType="FloatLabelType.Never"
                                        Placeholder="groups" CssClass="e-primary">
                        </SfDropDownList>
                        <AddressEntry DamageContext="location" AddressChanged="AddressChanged" ShowMap="false"></AddressEntry>
                    </div>
                </CardContent>
            </SfCard>
        </FormTemplate>
        <FormButtons>
            <SfButton type="submit" Disabled="_isValid" IsPrimary="true" OnClick="UpdateVendors">Search Vendors</SfButton>
        </FormButtons>
    </SfDataForm>
    <SfCard ID="map-container4" CssClass="map-container slide-in">
        <gmp-map role="region"></gmp-map>
    </SfCard>
    <SfCard>
        <CardContent EnableSeparator="true">
            <div class="vendors-container">
                @foreach (var item in vendors)
                {
                    <article class="vendor-card">
                        <div class="vendor-title">@item.Name</div>
                        @if (!string.IsNullOrWhiteSpace(item.Address))
                        {
                            <div class="vendor-line">@item.Address</div>
                        }
                        <div>
                            @if (!string.IsNullOrWhiteSpace(item.GoogleMaps))
                            {
                                <a href="@item.GoogleMaps" target="_blank" rel="noopener noreferrer">
                                    Place Map
                                </a>
                            }
                        </div>
                        <div>
                            @item.PrimaryTypeDisplayName
                        </div>
                        <div>
                            @string.Join(", ", item.Types ?? Array.Empty<string>())
                        </div>
                    </article>
                }
            </div>
        </CardContent>
    </SfCard>
</section>
<style>
    #map-container4 {
        height: 400px;
    }

    .category-header {
        align-self: normal;
    }

    .vendors-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vendor-card {
        padding: 10px 12px;
        border-bottom: 1px solid #e0e0e0;
        font-size: 0.9rem;
        line-height: 1.35;
    }

    .vendor-title {
        font-weight: 600;
        color: #202124;
        margin-bottom: 2px;
    }

    .vendor-line {
        color: #5f6368;
    }
</style>
@code {
    public EditContext EditContext { get; set; } = default!;

    DamageEntry location { get; set; } = new();

    string? category { get; set; }
    string[] categories = new[] { "general contractor", "plumber", "electrician", "roofer", "painter" };

    private bool isLoading { get; set; } = false;
    private bool _isValid;

    private PlaceDto[] vendors { get; set; } = [];
    private DotNetObjectReference<VendorManagement>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        EditContext = new EditContext(location);
        category = categories[0];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _objRef = DotNetObjectReference.Create(this);
    }

    public ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        return ValueTask.CompletedTask;
    }

    private void AddressChanged(bool isValid)
    {
        _isValid = isValid;
        if (!isValid) EditContext.Validate();
    }

    private async Task UpdateVendors()
    {
        isLoading = true;
        await jSRuntime.InvokeVoidAsync("googleMap.initMap", "#map-container4 > gmp-map", location.Latitude, location.Longitude, 16, _objRef, "OnVendorsMapped");
        await jSRuntime.InvokeVoidAsync("googleMap.fetchPlaces", category, 4);
        isLoading = false;
    }

    [JSInvokable]
    public async Task OnVendorsMapped(PlaceDto[]? places)
    {
        if (places is not null)
        {
            vendors = places;
            await vendorRepo.AddVendorsAsync(places);
        }
        return;
    }
}