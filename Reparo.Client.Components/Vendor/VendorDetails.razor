@rendermode InteractiveAuto

@inject IVendorRepo vendorRepo
@inject ToastService toastService

<div id="vendor-page" class="fade-in">
    @if (Vendor is not null)
    {
        <SfAppBar role="region">
            <h2>Vendor information</h2>
        </SfAppBar>
        <SfCard>
            <CardHeader>
                <h3>
                    @Vendor.Name
                </h3>
            </CardHeader>
            <CardContent>
                @if (!string.IsNullOrWhiteSpace(Vendor.LicenseNumber))
                {
                    <div>
                        <strong>License Number</strong><br />
                        @Vendor.LicenseNumber
                    </div>
                }
                <div>
                    <strong>Primary Type</strong><br />
                    @Vendor.PrimaryTypeDisplayName
                </div>
                <div>
                    <strong>Types</strong><br />
                    @string.Join(", ", Vendor.Types ?? Array.Empty<string>())
                </div>
                <div>
                    <strong>License Number</strong><br />
                    @Vendor.LicenseNumber
                </div>
            </CardContent>
        </SfCard>
        <SfCard>
            <CardHeader>
                <h3>Vendor Status</h3>
            </CardHeader>
            <CardContent>
                <div>
                    <strong>Status</strong> @Vendor.Status
                </div>
                <div>
                    <strong>Active</strong> @(Vendor.IsActive ? "Yes" : "No")
                </div>
                <div>
                    <strong>Verified</strong> @(Vendor.IsVerified ? "Yes" : "No")
                </div>
                <div>
                    <strong>Preferred</strong> @(Vendor.IsPreferred ? "Yes" : "No")
                </div>
            </CardContent>
        </SfCard>
        <SfCard>
            <CardHeader>
                <h3>Address</h3>
            </CardHeader>
            <CardContent>
                <div>
                    <strong>Address</strong><br />
                    @Vendor.Address
                </div>
                @if (!string.IsNullOrWhiteSpace(Vendor.GoogleMaps))
                {
                    <a href="@Vendor.GoogleMaps" target="_blank" rel="noopener noreferrer">
                        Place Map
                    </a>
                }
            </CardContent>
        </SfCard>
        <VendorMap Latitude="@Vendor.Latitude" Longitude="@Vendor.Longitude" PlaceId="@Vendor.PlaceId"></VendorMap>
    }
</div>
<style>
    #vendor-page {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
    }

        #vendor-page .e-card {
            flex: 1 1 260px;
        }
</style>

@code {
    [Parameter]
    public VendorModel Vendor { get; set; } = default!;
}