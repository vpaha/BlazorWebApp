@inject IVendorRepo vendorRepo

<SfGrid TValue="VendorModel"
        DataSource="@appVendors"
        Toolbar="@(new List<string> { "Search" })"
        AllowPaging="true"
        AllowReordering="true"
        AllowSorting="true"
        ShowColumnMenu="true">
    <GridPageSettings PageSize="GridConstants.RowCount" PageSizes="GridConstants.PageSizes"></GridPageSettings>
    <GridSearchSettings Fields="@(new[] { nameof(VendorModel.Name), nameof(VendorModel.Address), nameof(VendorModel.PrimaryType) })"
                        Operator="Syncfusion.Blazor.Operator.Contains"
                        IgnoreCase="true"
                        IgnoreAccent="true">
    </GridSearchSettings>
    <GridColumns>
        <GridColumn Field="@nameof(VendorModel.Name)" HeaderText="Name" IsPrimaryKey="true" AllowEditing="false"></GridColumn>
        <GridColumn Field="@nameof(VendorModel.Address)" HeaderText="Address"></GridColumn>
        <GridColumn Field="@nameof(VendorModel.PrimaryTypeDisplayName)" HeaderText="Primary Type Display Name"></GridColumn>
        <GridColumn Field="@nameof(VendorModel.PrimaryType)" HeaderText="Primary Type"></GridColumn>
    </GridColumns>
    <GridEvents TValue="VendorModel" RowSelected="OnRowSelected"></GridEvents>
</SfGrid>
@code {
    [Parameter]
    public EventCallback<VendorModel> OnVendorSelected { get; set; }

    private IReadOnlyList<VendorModel>? appVendors { get; set; }

    protected override async Task OnInitializedAsync()
    {
        appVendors = await vendorRepo.GetVendorListAsync();
    }

    private async Task OnRowSelected(RowSelectEventArgs<VendorModel> args)
    {
        if (args.Data is not null)
        {
            await OnVendorSelected.InvokeAsync(args.Data);
        }
    }
}