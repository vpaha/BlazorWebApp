@rendermode InteractiveAuto

@inject SfDialogService dialogService

<SfDialog Width="90vw" ShowCloseIcon="true" @bind-Visible="IsSearchDialogOpen">
    <DialogTemplates>
        <Header>Local contractors near the property</Header>
        <Content>
            <GoogleMap DamageContext="DamageContext" OnSelectionEvent="SelectedVendor" />
        </Content>
    </DialogTemplates>
</SfDialog>
@if (DamageContext.Vendor is not null)
{
    <div>
        <SfButton CssClass="e-success e-outline"
                  OnClick="ShowVendor" title="View Vendor Details">@DamageContext.Vendor.Name</SfButton>
        <SfButton CssClass="e-small e-round e-outline" OnClick="RemoveVendor" IconCss="e-icons e-close" title="Unassign this vendor"></SfButton>
    </div>
}
else
{
    <SfButton type="button" CssClass="e-success" OnClick="toggleSearch"
              Content="Find a local contractor" IconCss="e-icons e-search"
              IconPosition="IconPosition.Right" title="Find a local vendor"></SfButton>
}

@code {
    [Parameter] public DamageEntry DamageContext { get; set; } = default!;

    private bool IsSearchDialogOpen { get; set; }

    private async Task ShowVendor()
    {
        await dialogService.AlertAsync(null, "Vendor information", new DialogOptions
        {
            CssClass = "popup-dialog",
            ShowCloseIcon = true,

            PrimaryButtonOptions = new DialogButtonOptions
            {
                Content = "Close", IconCss = "e-icons e-close"
            },
            ChildContent = builder =>
            {
                builder.OpenComponent<VendorById>(0);
                builder.AddAttribute(1, "Vendor", DamageContext.Vendor);
                builder.CloseComponent();
            }
        });
    }

    private async Task toggleSearch()
    {
        IsSearchDialogOpen = !IsSearchDialogOpen;
    }

    private async Task RemoveVendor()
    {
        DamageContext.Vendor = null;
        DamageContext.VendorId = null;
        DamageContext.StatusId = DamageStatus.Reported;
        StateHasChanged();
    }
    
    private async Task SelectedVendor()
    {
        IsSearchDialogOpen = false;
    }
}